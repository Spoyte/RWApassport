# 🔧 Cross-Chain RWA Passport Environment Configuration

# =============================================================================
# BLOCKCHAIN NETWORK CONFIGURATION
# =============================================================================

# Avalanche Fuji Testnet
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_FUJI_CHAIN_ID=43113
AVALANCHE_MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Ethereum Sepolia Testnet
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
ETHEREUM_SEPOLIA_CHAIN_ID=11155111
ETHEREUM_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Additional Testnets (Optional)
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# =============================================================================
# PRIVATE KEYS (NEVER COMMIT THESE TO VERSION CONTROL)
# =============================================================================

# Deployer wallet private key (for contract deployment)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# User wallet private key (for testing)
USER_PRIVATE_KEY=your_user_private_key_here

# Oracle operator private key
ORACLE_PRIVATE_KEY=your_oracle_private_key_here

# =============================================================================
# CHAINLINK CONFIGURATION
# =============================================================================

# Chainlink CCIP Configuration
CHAINLINK_CCIP_ROUTER_FUJI=0xF694E193200268f9a4868e4Aa017A0118C9a8177
CHAINLINK_CCIP_ROUTER_SEPOLIA=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59

# LINK Token Addresses
LINK_TOKEN_FUJI=0x0b9d5D9136855f6FEc3c0993feE6E9CE8a297846
LINK_TOKEN_SEPOLIA=0x779877A7B0D9E8603169DdbD7836e478b4624789

# Chainlink Oracle Job Specifications
CHAINLINK_JOB_ID=your_job_id_here
CHAINLINK_ORACLE_ADDRESS=0x188b71C9d27cDeE01B9b0dfF5C1aff62E8D6F434
CHAINLINK_ORACLE_FEE=100000000000000000

# Price Feed Addresses (Fuji Testnet)
AVAX_USD_PRICE_FEED=0x5498BB568dd68f16b02Bc5598d0aD384f8c9c9b0
LINK_USD_PRICE_FEED=0x79c91fd4F8b3DaBEe17d286EB11cEE4D83521775

# =============================================================================
# SUZAKU INTEGRATION
# =============================================================================

# Suzaku Contract Addresses (Update with actual addresses)
SUZAKU_RESTAKING_CONTRACT=0x_SUZAKU_RESTAKING_CONTRACT_ADDRESS
SUZAKU_VALIDATOR_MANAGER=0x_SUZAKU_VALIDATOR_MANAGER_ADDRESS
SUZAKU_REWARDS_DISTRIBUTOR=0x_SUZAKU_REWARDS_DISTRIBUTOR_ADDRESS

# Suzaku Configuration
MINIMUM_STAKE_AMOUNT=1000000000000000000  # 1 token (18 decimals)
MINIMUM_VALIDATORS=3
SLASHING_THRESHOLD=10  # 10%

# =============================================================================
# ORACLE DATA SOURCES
# =============================================================================

# External API Endpoints for Oracle Verification
ART_AUTHENTICATION_API=https://api.artverify.com/v1
PROPERTY_REGISTRY_API=https://api.propertyregistry.gov/v1
CARBON_CREDIT_API=https://api.carbonregistry.org/v1
COMMODITY_EXCHANGE_API=https://api.commodityexchange.com/v1

# API Authentication
ART_VERIFICATION_API_KEY=your_art_api_key_here
PROPERTY_REGISTRY_API_KEY=your_property_api_key_here
CARBON_CREDIT_API_KEY=your_carbon_api_key_here

# =============================================================================
# IPFS/ARWEAVE STORAGE
# =============================================================================

# IPFS Configuration
IPFS_PROJECT_ID=your_ipfs_project_id
IPFS_PROJECT_SECRET=your_ipfs_project_secret
IPFS_GATEWAY_URL=https://ipfs.infura.io:5001

# Arweave Configuration (Alternative)
ARWEAVE_WALLET_PATH=./arweave-keyfile.json
ARWEAVE_GATEWAY_URL=https://arweave.net

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# React App Environment
REACT_APP_ENVIRONMENT=development
REACT_APP_CHAIN_ID=43113
REACT_APP_RPC_URL=${AVALANCHE_FUJI_RPC_URL}

# Contract Addresses (Will be populated after deployment)
REACT_APP_PASSPORT_REGISTRY_ADDRESS=
REACT_APP_CCIP_GATEWAY_ADDRESS=
REACT_APP_ORACLE_VERIFIER_ADDRESS=
REACT_APP_SUZAKU_INTEGRATION_ADDRESS=

# Web3 Provider Configuration
REACT_APP_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Hardhat Configuration
HARDHAT_NETWORK=fuji
GAS_REPORTER_ENABLED=true
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Etherscan API Keys for Contract Verification
ETHERSCAN_API_KEY=your_etherscan_api_key
SNOWTRACE_API_KEY=your_snowtrace_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# =============================================================================
# MONITORING AND ANALYTICS
# =============================================================================

# Application Monitoring
SENTRY_DSN=your_sentry_dsn_here
MIXPANEL_TOKEN=your_mixpanel_token_here

# Performance Monitoring
NEW_RELIC_LICENSE_KEY=your_new_relic_key_here
DATADOG_API_KEY=your_datadog_api_key_here

# =============================================================================
# HACKATHON SPECIFIC CONFIGURATION
# =============================================================================

# Demo Configuration
DEMO_MODE=true
MOCK_ORACLE_DATA=true
ENABLE_TEST_FAUCET=true

# Preset Demo Assets
DEMO_ASSET_1_TYPE=art
DEMO_ASSET_1_TITLE="Hackathon Digital Masterpiece"
DEMO_ASSET_1_ARTIST="AI Creator"

DEMO_ASSET_2_TYPE=carbon_credit
DEMO_ASSET_2_TITLE="Renewable Energy Carbon Credits"
DEMO_ASSET_2_QUANTITY=1000

# Cross-chain Demo Configuration
DEMO_SOURCE_CHAIN=43113  # Fuji
DEMO_DESTINATION_CHAIN=11155111  # Sepolia
DEMO_TRANSFER_AMOUNT=1

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Rate Limiting
API_RATE_LIMIT=100  # requests per minute
ORACLE_REQUEST_COOLDOWN=300  # seconds between requests

# Access Control
AUTHORIZED_ISSUERS=0x_ISSUER_1_ADDRESS,0x_ISSUER_2_ADDRESS
TRUSTED_ORACLES=0x_ORACLE_1_ADDRESS,0x_ORACLE_2_ADDRESS

# Emergency Controls
EMERGENCY_PAUSE_ENABLED=false
MAINTENANCE_MODE=false

# =============================================================================
# LOGGING AND DEBUGGING
# =============================================================================

# Log Levels
LOG_LEVEL=info  # debug, info, warn, error
VERBOSE_LOGGING=false

# Debug Flags
DEBUG_CONTRACTS=false
DEBUG_ORACLES=false
DEBUG_CCIP=false
DEBUG_FRONTEND=false

# =============================================================================
# PRODUCTION OVERRIDES (FOR LATER USE)
# =============================================================================

# Production Database
# DATABASE_URL=postgresql://user:password@localhost:5432/rwa_passport

# Production Redis Cache
# REDIS_URL=redis://localhost:6379

# Production API Keys
# PRODUCTION_API_KEY=your_production_api_key
# PRODUCTION_SECRET_KEY=your_production_secret_key

# =============================================================================
# NOTES FOR HACKATHON TEAMS
# =============================================================================

# 1. Copy this file to .env and fill in your actual values
# 2. Never commit the .env file to version control
# 3. Use the Avalanche Fuji faucet to get test AVAX: https://faucet.avax.network/
# 4. Get test LINK from Chainlink faucet: https://faucets.chain.link/
# 5. Create accounts on Infura, Alchemy, or similar for RPC access
# 6. For hackathon demo, you can use mock data for most oracle endpoints
# 7. Update contract addresses after deployment

# =============================================================================
# QUICK SETUP COMMANDS
# =============================================================================

# Install dependencies:
# npm install

# Compile contracts:
# npx hardhat compile

# Deploy to Fuji:
# npx hardhat run scripts/deploy.js --network fuji

# Run tests:
# npx hardhat test

# Start frontend:
# cd frontend && npm start 